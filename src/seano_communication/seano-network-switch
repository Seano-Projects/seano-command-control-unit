# Sudoers configuration for seano_communication node
# Allow seano user to run ip route commands without password
# 
# Installation:
#   sudo cp seano-network-switch /etc/sudoers.d/
#   sudo chmod 440 /etc/sudoers.d/seano-network-switch
#
seano ALL=(ALL) NOPASSWD: /usr/sbin/ip route replace default dev wwan0
seano ALL=(ALL) NOPASSWD: /usr/sbin/ip route replace default dev wlP1p1s0
seano ALL=(ALL) NOPASSWD: /usr/sbin/ip route replace default dev enP8p1s0
